PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/x7cyber
REDIS_URL=redis://localhost:6379
JWT_SECRET=change_me
PGSSL=false

# Comma-separated list of allowed frontend origins (production).
# Leave empty for permissive CORS in local development.
# Example: https://x7-cyber.vercel.app,https://app.example.com
CORS_ORIGINS=

# Outbound notification webhook (Discord-compatible or generic JSON).
NOTIFY_WEBHOOK_URL=

# AI assistant (optional, OpenAI-compatible). If unset, a rule-based engine is used.
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini

# External API keys (defensive use only)
NVD_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
IPINFO_TOKEN=
SHODAN_API_KEY=
