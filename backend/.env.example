# ============================================================
# X7 Cyber Security Platform - Backend Environment
# ============================================================
# Legenda:
#   [WAJIB]    harus diisi agar backend berjalan
#   [OPSIONAL] fitur tetap jalan tanpa ini (ada fallback gratis)
# ============================================================

# --- WAJIB --------------------------------------------------

# [WAJIB] Koneksi PostgreSQL.
# Railway/Render mengisi ini otomatis saat Anda menambah database.
DATABASE_URL=postgresql://user:password@localhost:5432/x7cyber

# [WAJIB] Rahasia untuk menandatangani JWT. JANGAN pakai nilai default.
# Generate: openssl rand -hex 32   (Render bisa generate otomatis)
JWT_SECRET=change_me

# --- KONFIGURASI DASAR (punya default aman) -----------------

# Port HTTP/WebSocket server.
PORT=4000

# Set 'true' jika database memerlukan SSL (umumnya true di Railway/Render).
PGSSL=false

# [PRODUKSI] Daftar origin frontend yang diizinkan, dipisah koma.
# Kosongkan untuk CORS permisif saat development lokal.
# Contoh: https://x7-cyber.vercel.app,https://app.example.com
CORS_ORIGINS=

# (Opsional) Redis untuk cache/queue. Saat ini queue berjalan in-memory.
REDIS_URL=redis://localhost:6379

# ============================================================
# SEMUA DI BAWAH INI OPSIONAL - platform berfungsi tanpa key
# ============================================================

# [OPSIONAL] Notifikasi keluar ke Discord / webhook generic (JSON).
# Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
NOTIFY_WEBHOOK_URL=

# [OPSIONAL] AI Security Assistant berbasis LLM (OpenAI-compatible).
# Jika AI_API_KEY kosong, otomatis memakai mesin rule-based gratis.
# Ambil key: https://platform.openai.com/api-keys
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini

# [OPSIONAL] Menaikkan rate limit pencarian CVE di NVD.
# Tanpa key tetap jalan, hanya lebih lambat / terbatas.
# Ambil key (gratis): https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# [OPSIONAL] Threat intelligence tambahan. Belum dipakai inti, siap untuk
# integrasi lanjutan. Semua menyediakan tier gratis.
# VirusTotal:  https://www.virustotal.com/gui/my-apikey
# AbuseIPDB:   https://www.abuseipdb.com/account/api
# IPinfo:      https://ipinfo.io/account/token
# Shodan:      https://account.shodan.io/  (InternetDB publik tidak butuh key)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
IPINFO_TOKEN=
SHODAN_API_KEY=
